---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Business Valuation Summit | I-Deals Network"
  description="Join our Business Valuation Summits. Past events held in Mumbai, Delhi, Bengaluru, and more."
  canonical="https://www.idealsnetwork.com/business-valuation-summit"
>
  <!-- Hero -->
  <div
    style="
      background: var(--navy);
      padding: 8rem clamp(1rem, 4vw, 2rem) 4rem;
      position: relative;
      overflow: hidden;
    "
  >
    <div
      style="
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 70% 50%, rgba(201,168,76,0.08) 0%, transparent 60%);
        pointer-events: none;
      "
    ></div>
    <div style="max-width: 720px; position: relative; z-index: 1;">
      <span class="section-label">Past Events</span>
      <span class="gold-rule" style="display: block; margin-top: 0.75rem;"></span>
      <h1
        style="
          font-family: 'Cormorant Garamond', serif;
          font-size: clamp(2rem, 5vw, 3.5rem);
          font-weight: 700;
          color: #fff;
          margin-bottom: 1.5rem;
          line-height: 1.1;
        "
      >Business Valuation Summit</h1>
      <p style="color: rgba(255,255,255,0.75); font-size: 1.05rem; line-height: 1.8; max-width: 600px;">
        Annual summits bringing together industry leaders, valuation experts, and finance professionals to discuss the latest trends and techniques in business valuation.
      </p>
    </div>
  </div>

  <!-- Events Grid -->
  <section style="padding: 4rem clamp(1rem, 4vw, 3rem); background: var(--cream);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2rem;">
        {[
          {
            date: 'June 19, 2019',
            title: 'Business Valuation Summit',
            location: 'Mumbai',
            venue: 'The Orchid Hotel',
            type: 'Conference',
            image: 'https://www.idealsnetwork.com/uploads/images/event/1660287735.png',
            link: 'https://idealsnetwork.com/business-valution-summit-201-mumbai',
          },
          {
            date: 'July 30, 2021',
            title: 'Business Valuation Summit',
            location: 'Delhi',
            venue: 'The Park',
            type: 'Conference',
            image: 'https://www.idealsnetwork.com/uploads/images/event/1661271240.jpg',
            link: 'https://idealsnetwork.com/bvs-delhi-30-july',
          },
          {
            date: 'March 6, 2019',
            title: 'Business Valuation Summit',
            location: 'Bengaluru',
            venue: 'Taj MG Road',
            type: 'Conference',
            image: 'https://www.idealsnetwork.com/uploads/images/event/1660997607.jpg',
            link: 'https://idealsnetwork.com/bv-summit-6-march',
          },
          {
            date: 'June 15, 2018',
            title: 'Business Valuation Summit',
            location: 'Delhi',
            venue: 'The Lalit',
            type: 'Conference',
            image: 'https://www.idealsnetwork.com/uploads/images/event/1660287122.png',
            link: 'https://idealsnetwork.com/bvs-15th-june',
          },
          {
            date: 'May 3, 2018',
            title: 'Business Valuation Summit',
            location: 'Mumbai',
            venue: 'The Westin, Mumbai',
            type: 'Conference',
            image: 'https://www.idealsnetwork.com/uploads/images/event/1661271468.png',
            link: 'https://idealsnetwork.com/bv-summit-3rd-may',
          },
          {
            date: 'January 17, 2018',
            title: 'Business Valuation Summit',
            location: 'Bengaluru',
            venue: 'Vivanta by Taj',
            type: 'Conference',
            image: 'https://www.idealsnetwork.com/uploads/images/event/1660998236.jpg',
            link: 'https://idealsnetwork.com/bv-summit-17-january',
          },
        ].map((event) => (
          <div class="event-card" style="overflow: hidden; padding: 0;">
            <div style="aspect-ratio: 16/9; overflow: hidden;">
              <img 
                src={event.image} 
                alt={event.title}
                style="width: 100%; height: 100%; object-fit: cover;"
                loading="lazy"
              />
            </div>
            <div style="padding: 1.5rem;">
              <div style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; color: var(--gold); margin-bottom: 0.5rem;">
                {event.date}
              </div>
              <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; font-weight: 600; color: var(--navy); margin-bottom: 0.75rem; line-height: 1.3;">
                {event.title}
              </h3>
              <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.75rem;">
                {event.venue && <span>{event.venue}</span>}
              </div>
              <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem;">
                <span class="event-tag">{event.location}</span>
                <span class="event-tag">{event.type}</span>
              </div>
              <a 
                href={event.link} 
                class="btn-navy"
                style="width: 100%; justify-content: center;"
              >
                Enquire Now
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section style="padding: 5rem clamp(1rem, 4vw, 3rem); background: var(--white);">
    <div style="max-width: 900px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3rem;">
        <span class="section-label">Why Attend</span>
        <span class="gold-rule-center" style="display: block; margin-top: 0.75rem;"></span>
        <h2 class="section-title">What to Expect</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
        {[
          {
            title: 'Expert Speakers',
            desc: 'Learn from leading valuation experts, investment bankers, and corporate finance professionals.',
          },
          {
            title: 'Networking',
            desc: 'Connect with peers and industry leaders from across the finance community.',
          },
          {
            title: 'Case Studies',
            desc: 'Real-world case studies and practical workshops on valuation methodologies.',
          },
          {
            title: 'Latest Trends',
            desc: 'Stay updated on the latest trends and techniques in business valuation.',
          },
        ].map((item) => (
          <div class="about-card">
            <div style="width: 40px; height: 40px; background: var(--navy); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-weight: 600; color: var(--navy); margin-bottom: 0.75rem;">
              {item.title}
            </h3>
            <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.7;">
              {item.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--navy); padding: 5rem clamp(1rem, 4vw, 3rem); text-align: center; position: relative; z-index: 1;">
    <div style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 4vw, 2.75rem); font-weight: 600; color: #fff; margin-bottom: 1.25rem;">
        Stay Updated on Future Summits
      </h2>
      <p style="color: rgba(255,255,255,0.65); font-size: 0.95rem; line-height: 1.75; margin-bottom: 2rem;">
        Register to be notified about upcoming Business Valuation Summits in your city.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://www.idealsnetwork.com/register" class="btn-gold" target="_blank" rel="noopener noreferrer">Register Now</a>
        <a href="/contact" class="btn-outline-gold">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

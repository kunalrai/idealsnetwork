---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About I-Deals Network | Mission, Vision & Global Finance Events Team"
  description="Learn about I-Deals Network's mission to connect entrepreneurs, investors, and dealmakers globally through world-class finance and M&A events."
  canonical="https://www.idealsnetwork.com/about-us"
>
  <!-- Hero -->
  <div
    style="
      background: var(--navy);
      padding: 8rem clamp(1rem, 4vw, 2rem) 4rem;
      position: relative;
      overflow: hidden;
    "
  >
    <div
      style="
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 70% 50%, rgba(201,168,76,0.08) 0%, transparent 60%);
        pointer-events: none;
      "
    ></div>
    <div style="max-width: 720px; position: relative; z-index: 1;">
      <span class="section-label">Our Story</span>
      <span class="gold-rule" style="display: block; margin-top: 0.75rem;"></span>
      <h1
        style="
          font-family: 'Cormorant Garamond', serif;
          font-size: clamp(2.5rem, 5vw, 4rem);
          font-weight: 700;
          color: #fff;
          margin-bottom: 1.5rem;
          line-height: 1.1;
        "
      >About I-Deals Network</h1>
      <p style="color: rgba(255,255,255,0.75); font-size: 1.05rem; line-height: 1.8; max-width: 600px;">
        A global platform uniting finance professionals through world-class events, expert-led workshops, and a network spanning 70+ countries.
      </p>
    </div>
  </div>

  <!-- Page summary -->
  <section
    class="page-summary"
    aria-label="Page overview"
    style="margin: 0; max-width: 1200px; margin-inline: auto; margin-top: -1px;"
  >
    I-Deals Network is a Delhi-based global events and education platform focused on investment banking, business valuation, mergers and acquisitions, and private equity. Founded to bridge the gap between knowledge and practice, the organisation runs hybrid workshops and summits in major financial centres including Singapore, Hong Kong, Mumbai, and Delhi. Our mission is to connect entrepreneurs, investors, lawyers, and analysts through industry-leading programmes. With 90+ events conducted, 8,000+ participants trained, and 500+ speakers hosted across 70+ countries, we are the premier community for finance and dealmaking professionals in Asia and beyond.
  </section>

  <!-- What we do -->
  <section style="padding: 5rem clamp(1rem, 4vw, 3rem); background: var(--cream); position: relative; z-index: 1;">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;">
      <div class="reveal">
        <span class="section-label">Our Purpose</span>
        <span class="gold-rule" style="display: block; margin-top: 0.75rem;"></span>
        <h2 class="section-title" style="margin-bottom: 1.25rem;">What We Do</h2>
        <p style="color: var(--text-muted); line-height: 1.85; font-size: 0.95rem; margin-bottom: 1rem;">
          Our platform endeavours to connect all stakeholders in the business fraternity — including entrepreneurs, investors, bankers, dealmakers, analysts, mentors, and advisers — across the globe through industry-leading events and summits.
        </p>
        <p style="color: var(--text-muted); line-height: 1.85; font-size: 0.95rem;">
          Each event is carefully curated to deliver actionable insights, practical skills, and meaningful professional relationships that participants carry forward in their careers.
        </p>
      </div>
      <div class="reveal reveal-delay-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        {[
          ['90+', 'Events Conducted'],
          ['8,000+', 'Participants Trained'],
          ['500+', 'Expert Speakers'],
          ['70+', 'Countries Reached'],
        ].map(([num, label]) => (
          <div style="background: var(--navy); padding: 1.75rem 1.5rem; text-align: center;">
            <div style="font-family: 'Cormorant Garamond', serif; font-size: 2.25rem; font-weight: 700; color: var(--gold); line-height: 1;">{num}</div>
            <div style="font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-top: 0.4rem;">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mission, Vision, Team -->
  <section style="padding: 5rem clamp(1rem, 4vw, 3rem); background: var(--white); position: relative; z-index: 1;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div class="reveal" style="margin-bottom: 3rem; text-align: center;">
        <span class="section-label">Our Foundation</span>
        <span class="gold-rule-center" style="display: block; margin-top: 0.75rem;"></span>
        <h2 class="section-title">Mission, Vision & Team</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
        {[
          {
            title: 'Mission',
            body: 'We aim to be a nesting ground for entrepreneurs to embark on their dream journey and a networking platform for fledgling ventures to scale up business — imparting knowledge and offering analysis and insights through training, education, assessment, and evaluation.',
          },
          {
            title: 'Vision',
            body: 'I-Deals Network envisions being the preferred platform that connects investment, banking, and law firms with financial and corporate entities — building lasting relationships that drive deals and careers forward.',
          },
          {
            title: 'Our Team',
            body: 'Dedicated to building matchless services across all incorporated divisions of our business. We team up with problem solvers, excellent speakers, writers, trainers, and creative thinkers who share our passion for connecting people and knowledge.',
          },
        ].map((item, i) => (
          <div class={`about-card reveal reveal-delay-${i + 1}`}>
            <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: var(--navy); margin-bottom: 1rem;">{item.title}</h3>
            <div style="width: 32px; height: 2px; background: var(--gold); margin-bottom: 1rem;"></div>
            <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.85;">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--navy); padding: 5rem clamp(1rem, 4vw, 3rem); text-align: center; position: relative; z-index: 1;">
    <div class="reveal" style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 4vw, 2.75rem); font-weight: 600; color: #fff; margin-bottom: 1.25rem;">
        Ready to Join the Network?
      </h2>
      <p style="color: rgba(255,255,255,0.65); font-size: 0.95rem; line-height: 1.75; margin-bottom: 2rem;">
        Register to attend our upcoming events or reach out to partner with us, speak at an event, or request a customised training programme.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://www.idealsnetwork.com/register" class="btn-gold" target="_blank" rel="noopener noreferrer">Register Now</a>
        <a href="/contact" class="btn-outline-gold">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (max-width: 768px) {
    section > div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }
  }
</style>

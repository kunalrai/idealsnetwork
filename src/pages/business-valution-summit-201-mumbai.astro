---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Business Valuation Summit 2019 Mumbai | I-Deals Network"
  description="Business Valuation Summit 2019 held in Mumbai at The Orchid Hotel. Connect with industry experts and regulators."
  canonical="https://www.idealsnetwork.com/business-valution-summit-201-mumbai"
>
  <div style="background: var(--navy); padding: 8rem clamp(1rem, 4vw, 2rem) 4rem; position: relative; overflow: hidden;">
    <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 50%, rgba(201,168,76,0.08) 0%, transparent 60%); pointer-events: none;"></div>
    <div style="max-width: 720px; position: relative; z-index: 1;">
      <span class="section-label">Past Event</span>
      <span class="gold-rule" style="display: block; margin-top: 0.75rem;"></span>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; color: #fff; margin-bottom: 1.5rem; line-height: 1.1;">
        Business Valuation Summit 2019
      </h1>
      <p style="color: rgba(255,255,255,0.75); font-size: 1.05rem; line-height: 1.8; max-width: 600px;">
        June 19, 2019 | Mumbai, India | The Orchid Hotel
      </p>
    </div>
  </div>

  <section style="padding: 4rem clamp(1rem, 4vw, 3rem); background: var(--cream);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; font-weight: 600; color: var(--navy); margin-bottom: 1.5rem;">About the Summit</h2>
      <p style="color: var(--text-muted); line-height: 1.9; font-size: 1rem; margin-bottom: 2rem;">
        With a population of over 1.25 billion, India is one of the biggest and fastest growing economies in the world. Standards and professionalism are of significant importance. The summit brought together experts from regulators, corporations, and the corporate affairs ministry to discuss the future of Valuation in India.
      </p>
      
      <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: var(--navy); margin-bottom: 1rem;">Meet Our Experts</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        {[
          { name: 'Sahil Narula', title: 'Director', company: 'RNC' },
          { name: 'Rajesh Khairajani', title: 'Partner', company: 'KNAV' },
          { name: 'Mr. Darpit Kanadia', title: 'Partner', company: 'Baker Tilly DHC' },
          { name: 'Chander Sawhney', title: 'Partner Valuation', company: 'Corporate Professionals' },
          { name: 'Mr. Nalin Kumar', title: 'Head Investment Banking', company: 'IDBI Capital' },
          { name: 'Shailesh Hari', title: 'Chairman', company: 'SH & Associates' },
          { name: 'Pratik Singhi', title: 'Partner', company: 'Nine Rivers Capital' },
          { name: 'Amit Mehra', title: 'Principal', company: 'Unicorn India Ventures' },
        ].map(speaker => (
          <div style="background: var(--white); padding: 1rem; border-left: 3px solid var(--gold);">
            <div style="font-weight: 600; color: var(--navy); font-size: 0.95rem;">{speaker.name}</div>
            <div style="font-size: 0.8rem; color: var(--text-muted);">{speaker.title}, {speaker.company}</div>
          </div>
        ))}
      </div>

      <div style="background: var(--white); padding: 2rem; border-left: 4px solid var(--gold);">
        <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: var(--navy); margin-bottom: 1rem;">Venue</h3>
        <p style="color: var(--text-muted); line-height: 1.8;">
          <strong>The Orchid Hotel</strong><br/>
          Mumbai, India
        </p>
      </div>
    </div>
  </section>

  <section style="background: var(--navy); padding: 4rem clamp(1rem, 4vw, 3rem); text-align: center;">
    <div style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 600; color: #fff; margin-bottom: 1.25rem;">
        Interested in Future Events?
      </h2>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://www.idealsnetwork.com/register" class="btn-gold" target="_blank" rel="noopener noreferrer">Register Now</a>
        <a href="/contact" class="btn-outline-gold">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

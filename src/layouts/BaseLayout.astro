---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  jsonLd?: object[];
}

const { title, description, canonical, jsonLd = [] } = Astro.props;
const siteUrl = 'https://www.idealsnetwork.com';
const canonicalUrl = canonical ?? siteUrl + Astro.url.pathname;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "I-Deals Network",
  "url": siteUrl,
  "logo": `${siteUrl}/logo.png`,
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+91-9953285105",
    "contactType": "customer service",
    "email": "register@idealsnetwork.com"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "B-756, Bunkar Colony, Ashok Vihar Phase-IV",
    "addressLocality": "Delhi",
    "postalCode": "110052",
    "addressCountry": "IN"
  },
  "sameAs": [
    "https://www.facebook.com/networkideals",
    "https://twitter.com/idealsnetwork",
    "https://www.youtube.com/c/IDealsNetwork",
    "https://www.linkedin.com/company/i-dealsnetwork",
    "https://instagram.com/idealsnetwork"
  ]
};

const allSchemas = [orgSchema, ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${siteUrl}/logo.png`} />
    <meta property="og:site_name" content="I-Deals Network" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@idealsnetwork" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- JSON-LD -->
    {allSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <Nav />
    <main style="position:relative;z-index:0;">
      <slot />
    </main>
    <Footer />

    <!-- Floating WhatsApp -->
    <a
      href="https://wa.me/+919650920078"
      aria-label="Contact us on WhatsApp"
      target="_blank"
      rel="noopener noreferrer"
      style="
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 200;
        width: 52px;
        height: 52px;
        background: #25D366;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px rgba(37,211,102,0.45);
        transition: transform 0.2s, box-shadow 0.2s;
      "
      onmouseenter="this.style.transform='scale(1.1)';this.style.boxShadow='0 6px 24px rgba(37,211,102,0.55)'"
      onmouseleave="this.style.transform='scale(1)';this.style.boxShadow='0 4px 16px rgba(37,211,102,0.45)'"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <!-- Scroll reveal -->
    <script>
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
        { threshold: 0.12 }
      );
      reveals.forEach(el => observer.observe(el));
    </script>

    <!-- Nav scroll effect -->
    <script>
      const nav = document.querySelector('nav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 60) nav?.classList.add('scrolled');
        else nav?.classList.remove('scrolled');
      }, { passive: true });
    </script>

    <!-- Mobile nav toggle -->
    <script>
      const hamburger = document.getElementById('hamburger');
      const navLinksWrap = document.getElementById('nav-links-wrap');
      hamburger?.addEventListener('click', () => navLinksWrap?.classList.toggle('open'));
    </script>
  </body>
</html>

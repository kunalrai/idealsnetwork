  <!-- end common css -->

  </head>
<body data-base-url="https://www.idealsnetwork.com">

  <script src="https://www.idealsnetwork.com/assets/js/spinner.js"></script>

  <div class="main-wrapper" id="app">
    <div class="page-wrapper full-page">
      <div class="page-content d-flex align-items-center justify-content-center">

  <div class="row w-100 mx-0 auth-page">
    <div class="col-md-8 col-xl-6 mx-auto d-flex flex-column align-items-center">
      <img src="https://www.idealsnetwork.com/assets/images/others/404.svg" class="img-fluid mb-2" alt="404">
      <h1 class="fw-bolder mb-22 mt-2 tx-80 text-muted">404</h1>
      <h4 class="mb-2">Page Not Found</h4>
      <h6 class="text-muted mb-3 text-center">Oopps!! The page you were looking for doesn't exist.</h6>
      <a href="https://www.idealsnetwork.com">Back to home</a>
    </div>
  </div>

</div>
    </div>
  </div>

    <!-- base js -->
